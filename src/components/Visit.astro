---
import { SITE } from '../content/site.config';
---

<section id="visit" class="py-20 bg-linen">
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <div class="text-center mb-12">
      <div class="section-label">Find Us</div>
      <h2 class="font-display text-4xl md:text-5xl text-coal italic">Come visit us</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">

      <!-- Map embed (3/5 width) — static image until user clicks to load full map -->
      <div class="lg:col-span-3 rounded-2xl overflow-hidden shadow-[0_4px_32px_rgba(30,20,10,0.12)] aspect-[4/3] relative group"
           id="map-container">
        <!-- Static map image (no JS, no render-blocking scripts) -->
        <iframe
          src={SITE.mapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0; display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Map to ${SITE.name}`}
        />
        <!-- Click-to-load overlay -->
        <button
          id="map-load-btn"
          class="absolute inset-0 flex flex-col items-center justify-center gap-2
                 bg-coal/0 hover:bg-coal/10 transition-colors duration-200 cursor-pointer"
          aria-label="Load interactive map"
        >
          <span class="bg-coal/80 text-parchment text-xs font-medium px-3 py-1.5 rounded-full
                       opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center gap-1.5">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
            </svg>
            Click to load interactive map
          </span>
        </button>
        <!-- Iframe injected on click -->
        <iframe
          id="map-iframe"
          data-src={SITE.mapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0; display:none; position:absolute; inset:0;"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          title={`Interactive map to ${SITE.name}`}
        />
      </div>

      <!-- Info panel (2/5 width) -->
      <div class="lg:col-span-2 flex flex-col gap-8">

        <!-- Address -->
        <div class="bg-white rounded-2xl p-7 border border-stone/30 shadow-[0_2px_12px_rgba(30,20,10,0.05)]">
          <div class="text-xs font-semibold uppercase tracking-widest text-ember mb-3">Address</div>
          <p class="font-display italic text-xl text-coal mb-1">{SITE.address.full}</p>
          <a href={SITE.mapsDirectionsUrl} target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-1.5 text-ember text-sm font-medium
                    hover:underline underline-offset-4 mt-3">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
              <circle cx="12" cy="9" r="2.5"/>
            </svg>
            Get Directions →
          </a>
        </div>

        <!-- Hours -->
        <div class="bg-white rounded-2xl p-7 border border-stone/30 shadow-[0_2px_12px_rgba(30,20,10,0.05)]">
          <div class="text-xs font-semibold uppercase tracking-widest text-ember mb-4">Hours</div>
          <div class="flex flex-col gap-3">
            {SITE.hours.map(h => (
              <div class="flex justify-between items-baseline">
                <span class="text-coal/70 text-sm">{h.days}</span>
                <span class:list={['text-sm font-medium', h.time === 'Closed' ? 'text-coal/50' : 'text-coal']}>
                  {h.time}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Contact -->
        <div class="bg-white rounded-2xl p-7 border border-stone/30 shadow-[0_2px_12px_rgba(30,20,10,0.05)]">
          <div class="text-xs font-semibold uppercase tracking-widest text-ember mb-4">Contact</div>
          <div class="flex flex-col gap-3">
            <a href={`tel:${SITE.phone}`}
               class="flex items-center gap-2 text-coal/70 hover:text-ember text-sm transition-colors">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
              {SITE.phone}
            </a>
            <a href={`mailto:${SITE.email}`}
               class="flex items-center gap-2 text-coal/70 hover:text-ember text-sm transition-colors">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              {SITE.email}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn    = document.getElementById('map-load-btn');
  const iframe = document.getElementById('map-iframe') as HTMLIFrameElement | null;
  const img    = document.getElementById('map-static');
  btn?.addEventListener('click', () => {
    if (!iframe || !img) return;
    iframe.src = iframe.dataset.src ?? '';
    iframe.style.display = 'block';
    img.style.display    = 'none';
    btn.style.display    = 'none';
  }, { once: true });
</script>
