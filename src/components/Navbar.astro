---
import { SITE } from '../content/site.config';
const links = [
  { label: 'Menu',        href: '#menu' },
  { label: 'About',       href: '#about' },
  { label: 'Visit Us',    href: '#visit' },
  { label: 'Events',      href: '#events' },
];
---

<nav class="sticky top-0 z-50 flex items-center justify-between
            px-6 md:px-10 py-4 bg-coal border-b border-white/10
            shadow-[0_2px_20px_rgba(0,0,0,0.3)]">

  <a href="/" class="font-display text-2xl italic text-parchment tracking-tight">
    {SITE.name}
  </a>

  <ul class="hidden md:flex gap-8 list-none">
    {links.map(l => (
      <li>
        <a href={l.href}
           class="text-sm font-medium text-parchment/60 hover:text-parchment transition-colors duration-200">
          {l.label}
        </a>
      </li>
    ))}
  </ul>

  <a href={SITE.reservationsUrl} target="_blank" rel="noopener noreferrer"
     class="btn-primary text-sm hidden md:inline-flex">
    Reserve a Table
  </a>

  <button id="mob-btn" class="md:hidden text-parchment" aria-label="Toggle menu">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="2" y1="6"  x2="20" y2="6"  id="l1"/>
      <line x1="2" y1="11" x2="20" y2="11" id="l2"/>
      <line x1="2" y1="16" x2="20" y2="16" id="l3"/>
    </svg>
  </button>
</nav>

<div id="mob-menu"
     class="hidden fixed inset-x-0 top-[61px] z-40 bg-coal border-b border-white/10
            flex-col px-6 py-6 gap-4 md:hidden">
  {links.map(l => (
    <a href={l.href} class="text-parchment/70 hover:text-parchment text-base py-1">{l.label}</a>
  ))}
  <a href={SITE.reservationsUrl} target="_blank" class="btn-primary text-center mt-2">
    Reserve a Table
  </a>
</div>

<script>
  const btn  = document.getElementById('mob-btn')!;
  const menu = document.getElementById('mob-menu')!;
  btn.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
  });
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    menu.classList.add('hidden'); menu.classList.remove('flex');
  }));
</script>
