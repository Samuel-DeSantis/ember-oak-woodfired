---
import { SITE } from '../content/site.config';
---

<section id="about" class="bg-coal py-20">
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <div class="text-center mb-14">
      <div class="text-gold text-xs font-semibold uppercase tracking-widest mb-2">Our Philosophy</div>
      <h2 class="font-display text-4xl md:text-5xl text-parchment italic leading-tight">
        The fire does the talking
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {SITE.features.map(f => (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-7
                    hover:bg-white/8 hover:border-white/20 transition-all duration-200">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="font-display text-parchment italic text-xl mb-2">{f.title}</h3>
          <p class="text-parchment/45 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
