---
import { SITE } from '../content/site.config';
const year = new Date().getFullYear();
const socials = Object.entries(SITE.social).filter(([,v]) => v !== '');
---

<footer class="bg-coal border-t border-white/10 py-10 px-6 md:px-10">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center
              justify-between gap-6">

    <div class="text-center md:text-left">
      <div class="font-display text-parchment italic text-xl mb-1">{SITE.name}</div>
      <div class="text-parchment/35 text-xs">{SITE.address.full}</div>
    </div>

    <div class="flex items-center gap-6">
      {socials.map(([platform, url]) => (
        <a href={url} target="_blank" rel="noopener noreferrer"
           class="text-parchment/40 hover:text-parchment text-sm capitalize transition-colors">
          {platform}
        </a>
      ))}
    </div>

    <div class="text-parchment/30 text-xs text-center md:text-right">
      © {year} {SITE.name}<br />
      <a href={`tel:${SITE.phone}`} class="hover:text-parchment/60 transition-colors">{SITE.phone}</a>
    </div>
  </div>
</footer>
