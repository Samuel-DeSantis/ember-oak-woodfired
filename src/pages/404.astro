---
import Base   from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Page Not Found" noindex={true}>
  <Navbar />
  <main class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 py-24">
    <p class="font-display text-8xl opacity-10 mb-4">404</p>
    <h1 class="font-display text-3xl mb-3">Page Not Found</h1>
    <p class="opacity-50 mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="btn-primary">← Back to Home</a>
  </main>
  <Footer />
</Base>
