---
import Base   from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Message Received" noindex={true}>
  <Navbar />
  <main class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 py-24">
    <div class="text-5xl mb-6">✓</div>
    <h1 class="font-display text-4xl mb-4">Message Received!</h1>
    <p class="opacity-60 text-lg max-w-sm mb-8">We'll be in touch within one business day.</p>
    <a href="/" class="btn-primary">← Back to Home</a>
  </main>
  <Footer />
</Base>
